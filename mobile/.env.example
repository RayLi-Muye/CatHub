# Mobile API base URL. Use the LAN IP of your dev machine, the Vercel preview
# URL for the current branch, or the production URL.
#   Local dev (same Wi-Fi): http://192.168.x.y:3000
#   Vercel preview:         https://cathub-git-<branch>-<scope>.vercel.app
#   Production:             https://cathub.app (or your domain)
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000

# Only required when hitting a Vercel preview deployment with Deployment
# Protection enabled. Generate at:
#   Vercel project → Settings → Deployment Protection
#     → Protection Bypass for Automation → Generate token
# Leave blank for local dev or production. The mobile API client will attach
# x-vercel-protection-bypass and x-vercel-set-bypass-cookie headers when set.
EXPO_PUBLIC_VERCEL_PROTECTION_BYPASS=
